        function signOut() {
            // Example: Remove user-related session or cookies
            sessionStorage.removeItem('UserId'); // or use localStorage, depending on your setup
            sessionStorage.removeItem('token');

            // Redirect to login page or home page after sign-out
            window.location.href = "../web/index.aspx";  // Replace with your actual login route
        }



    </script>




