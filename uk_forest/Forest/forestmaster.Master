    <style>
        .dropdown-action {
            padding: 10px;
            border-radius: 20px;
            border: 1px solid #038d5b;
            background-color: #f5faff;
            font-weight: bold;
            width: 100%;
            font-size: 14px;
        }
        .dropdown-action:focus {
            border-color: #0056b3;
            outline: none;
            box-shadow: 0 0 0 3px rgba(0,123,255,0.2);
        }
        .dropdown-item.active{
            background-color:#28a847 !important;
            color:#fff !important;
        }
        .card .card-header {
            border-bottom: 0;
            background-color: #1186c5;
            color: #fff;
            padding: 15px;
        }

        .tableColumn table tr th {
            padding: 10px 5px;
            background-color: #bcffdd;
            font-size: 14px;
            color: #000;
        }

        tbody, td, tfoot, th, thead, tr {
            border-color: inherit;
            border-style: solid;
            border-width: thin;
            padding: 0px 5px;
        }

        .accessRightTable table tr th {
            padding: 10px 5px;
            background-color: #bcffdd;
            font-size: 14px;
            color: #000;
        }

        .accessRightTable table tr td {
            padding: 10px 5px;
            font-size: 14px;
        }

        .btn_assign input#ContentPlaceHolder1_btnAssign {
            background-color: #05476b;
            color: #ffffff;
            border-color: #05476b;
        }

        .uploadData input#ContentPlaceHolder1_fileUploadTextBox {
            border: 1px solid green;
            border-radius: 50px;
            width: 100%;
            height: 41px !important;
            display: inline-block;
        }

        .uploadData select {
            border: 1px solid green;
            border-radius: 50px;
            width: 100%;
            height: 41px !important;
            display: inline-block;
        }

        .uploadData input#ContentPlaceHolder1_btnUploadData {
            padding: 10px;
            background-color: #05476b;
            color: #ffffff;
            border-color: #000;
            border: none;
            font-weight: 500;
        }

        input#ContentPlaceHolder1_btn_save {
            background-color: #05476b;
            color: #ffffff;
            border: none;
        }

        input#ContentPlaceHolder1_btnSave {
            background-color: #1c1c1c;
            border: 0;
        }

        input#ContentPlaceHolder1_btnback {
            background-color: #1c1c1c;
            border: 0;
        }

        input#ContentPlaceHolder1_btn_update {
            background-color: #05476b;
            color: #ffffff;
            border: none;
        }

        span.aspNetDisabled {
            display: flex;
            gap: 10px;
        }

        .tab-content-wrapper .titleHeading {
            font-weight: 700 !important;
            color: #13460c;
            margin-top: 20px;
            font-size: 30px;
        }

        .table-striped > tbody > tr:nth-of-type(odd) > * {
            --osen-table-color-type: #ffffff;
            --osen-table-bg-type: rgb(4 96 134);
        }

        .grid-container .table th {
            padding: 12px !important;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        .grid-container .table td {
            padding: 10px !important;
        }





